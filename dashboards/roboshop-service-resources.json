        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(kube_deployment_status_replicas_ready{namespace=\"roboshop\", deployment=\"roboshop-$service\"})",
          "refId": "A",
          "instant": true
