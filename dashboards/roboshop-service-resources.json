        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "definition": "label_values(kube_deployment_spec_replicas{namespace=\"roboshop\", deployment=~\"roboshop-.*\"}, deployment)",
        "query": {
          "qryType": 1,
          "query": "label_values(kube_deployment_spec_replicas{namespace=\"roboshop\", deployment=~\"roboshop-.*\"}, deployment)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "regex": "/^roboshop-(.*)$/",
        "current": {
          "selected": false,
          "text": "user",
          "value": "user"
        },
        "refresh": 1,
        "sort": 1,
        "multi": false,
        "includeAll": false,
        "hide": 0
